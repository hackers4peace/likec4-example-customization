model {
  userId = ThreatContainer 'C1 End User CID Provider' {
    cid = Process 'P1 CID' {
      metadata {
        _shape 'process'
      }
    }
  }
  userAs = ThreatContainer 'C1 End User Auth / IdP' {
    as = Process 'P2 End User Authorization Server / IdP' {
      metadata {
        _shape 'process'
      }
    }
    key = DataObject 'O1 Private Key' {
      style {
        color pink
      }
      metadata {
        _shape 'data-object'
      }
    }
  }

  app = ThreatContainer 'C2 Application Provider' {
    client = Process 'P3 Application' {
      metadata {
        _shape 'process'
      }
    }
  }

  owner = ThreatContainer 'C3 Resource Owner' {
    storage = Process 'P4 Resource Server' {
      metadata {
        _shape 'process'
      }
    }
    as = Process 'P5 Resource Server Authorization Server' {
      metadata {
        _shape 'process'
      }
    }
  }

  userActor = ExternalEntity 'E1 User'
  appActor = ExternalEntity 'E2 Application Admin'
  ownerActor = ExternalEntity 'E3 Resource Owner'

  userId.cid -> userAs.as 'F1 designates authn service'
  userAs.as -> userAs.key 'F2 signs AuthN Credentials with'
  app.client -> userId.cid 'F3 discovers AuthN Service'
  app.client -> userAs.as 'F4 obtains AuthN Credential'
  owner.as -> userId.cid 'F5 discovers AuthN Service'
  owner.as -> userAs.as 'F6 obtains public key'
  owner.as -> owner.storage 'F7 issues access tokens for'
  app.client -> owner.as 'F8 exchanges credential for token'
  userActor -> userId 'F9 controlls'
  userActor -> userAs 'F10 controlls'
  appActor -> app 'F11 controlls'
  ownerActor -> owner 'F12 controlls'
  userActor -> app.client 'F13 uses'
  app.client -> owner.storage 'F14 accesses data '

}

views {
  view lws {
    include
    userId, userAs, userId.*, userAs.*, userActor,
    app, app.*, appActor,
    owner, owner.*, ownerActor
  }
}
